# ─── LLM Director: Gemini (cloud, optional) ─────────────────────────────────
# Gemini 3.5 Flash (GA May 2026) is the PRIMARY director when configured.
# Better prompt adherence + reasoning than local Qwen3-8B, and it holds the
# whole transcript (1M input tokens / 65K output) in a single request — so
# when available the pipeline doesn't even chunk. If Gemini is not set or
# unreachable, the pipeline falls back to local Qwen3-8B automatically.
#
# Free-tier availability (Google AI Studio, no billing required):
#   - gemini-3.5-flash             ✅ free tier (RECOMMENDED)
#   - gemini-3-flash-preview       ✅ free tier (older alias of the 3.x line)
#   - gemini-3.1-flash-lite        ✅ free tier (cheapest, smallest)
#   - gemini-2.5-flash             ✅ free tier (still supported)
#   - gemini-3.1-pro-preview       ❌ requires paid Tier 1 (free keys get 403)
#   - gemini-3-flash               ❌ not a valid model name (404 NOT_FOUND)
#
# Google no longer publishes static RPM/TPM/RPD per model — view YOUR
# account's live limits at https://aistudio.google.com/rate-limit .
#
# 1) Get an API key: https://aistudio.google.com/app/apikey
#    NOTE: requires a Google account registered in a SUPPORTED region
#    (Russia is NOT supported — the API geoblocks by caller IP).
# 2) Set the proxy to egress from a supported region. A datacenter proxy/VPS
#    works (the API keys on IP, not residential status).

CLIPFORGE_GEMINI_ENABLED=true
CLIPFORGE_GEMINI_API_KEY=
# Proxy URL: http://user:pass@host:port  or  socks5://host:port
CLIPFORGE_GEMINI_PROXY=
CLIPFORGE_GEMINI_MODEL=gemini-3.5-flash
# Pre-flight check cached this long to save RPD on the free tier. Set 0 to
# disable caching (run pre-flight every video). 300s = 5 min covers a typical
# batch; default is conservative for 20 RPD/day budgets.
CLIPFORGE_GEMINI_HEALTH_TTL=300
# Retries on transient 5xx/429/timeout before falling back to Qwen.
# Worst-case wait: 5 + 10 + 20 = 35s with BASE_DELAY=5.
CLIPFORGE_GEMINI_MAX_RETRIES=3
CLIPFORGE_GEMINI_RETRY_DELAY=5
CLIPFORGE_GEMINI_TIMEOUT=120

# ─── Whisper ────────────────────────────────────────────────────────────────
# Model size: tiny (~75MB), base (~150MB), small (~500MB), medium (~1.5GB)
# Larger models are more accurate but slower
WHISPER_MODEL=base

# ─── Backend / Frontend ────────────────────────────────────────────────────
# Backend host and port (default: localhost:8000)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend port (default: 5173)
FRONTEND_PORT=5173
